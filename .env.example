# ============================================================
# Sazón Caribeño — Variables de Entorno
# Copia a .env y ajusta valores para tu entorno local.
# En producción (Render), configura estas en el Dashboard.
# ============================================================

# --- Base de datos ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=sazon_caribeno
DB_PORT=3306

# O bien, URL directa (sobreescribe DB_* si se define):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/sazon_caribeno

# --- Seguridad ---
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# --- CORS (orígenes separados por coma) ---
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# --- Heartbeat ---
HEARTBEAT_INTERVAL_SECONDS=300
HEARTBEAT_TIMEOUT_SECONDS=900

# --- Red ---
ALLOWED_IP=192.168.1.0/24
